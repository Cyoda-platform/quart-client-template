<+># Here's a Python code implementation that fetches data from the external data source specified in the Restful Booker API. The code includes the `ingest_data` function, which retrieves booking data and saves it to the `raw_bookings_entity`. Additionally, the implementation includes unit tests with mocks for external services.\n# \n# ```python\nimport requests\nimport logging\nfrom unittest import TestCase\nfrom unittest.mock import patch, MagicMock\n\n# Configure logging\nlogging.basicConfig(level=logging.INFO)\nlogger = logging.getLogger(__name__)\n\ndef ingest_data(booking_id, token):\n    \"\"\"\n    Fetches booking data from the Restful Booker API and saves it to raw_bookings_entity.\n\n    :param booking_id: The ID of the booking to retrieve.\n    :param token: The authentication token for the entity service.\n    :return: The ID of the saved raw booking entity.\n    \"\"\"\n    url = f\"https://restful-booker.herokuapp.com/booking/{booking_id}\"\n    \n    headers = {\n        \"Accept\": \"application/json\"\n    }\n\n    try:\n        logger.info(f\"Fetching booking data for ID: {booking_id}\")\n        response = requests.get(url, headers=headers)\n        response.raise_for_status()  # Raise an HTTPError for bad responses\n\n        booking_data = response.json()\n        \n        # Mapping the fetched data to the raw booking entity structure if needed\n        raw_booking_entity = {\n            \"firstname\": booking_data[\"firstname\"],\n            \"lastname\": booking_data[\"lastname\"],\n            \"totalprice\": booking_data[\"totalprice\"],\n            \"depositpaid\": booking_data[\"depositpaid\"],\n            \"bookingdates\": booking_data[\"bookingdates\"],\n            \"additionalneeds\": booking_data.get(\"additionalneeds\", \"\")\n        }\n\n        # Assume `entity_service` is a service that handles entity operations\n        raw_booking_entity_id = entity_service.add_item(\n            token,\n            \"raw_bookings_entity\",\n            \"ENTITY_VERSION\",  # Assuming a predefined version identifier\n            raw_booking_entity\n        )\n        \n        logger.info(f\"Raw booking entity saved successfully with ID: {raw_booking_entity_id}\")\n        return raw_booking_entity_id\n    \n    except Exception as e:\n        logger.error(f\"Error during data ingestion: {e}\")\n        raise\n\n# Unit Test Class\nclass TestIngestData(TestCase):\n\n    @patch('requests.get')\n    @patch('entity_service.add_item')\n    def test_ingest_data(self, mock_add_item, mock_get):\n        # Arrange\n        mock_get.return_value = MagicMock(status_code=200)\n        mock_get.return_value.json.return_value = {\n            \"firstname\": \"Sally\",\n            \"lastname\": \"Brown\",\n            \"totalprice\": 111,\n            \"depositpaid\": True,\n            \"bookingdates\": {\n                \"checkin\": \"2013-02-23\",\n                \"checkout\": \"2014-10-23\"\n            },\n            \"additionalneeds\": \"Breakfast\"\n        }\n        mock_add_item.return_value = \"raw_bookings_entity_id\"\n        \n        booking_id = 1\n        token = \"test_token\"\n\n        # Act\n        result = ingest_data(booking_id, token)\n\n        # Assert\n        mock_get.assert_called_once_with(f\"https://restful-booker.herokuapp.com/booking/{booking_id}\", headers={\"Accept\": \"application/json\"})\n        mock_add_item.assert_called_once_with(\n            token,\n            \"raw_bookings_entity\",\n            \"ENTITY_VERSION\",\n            {\n                \"firstname\": \"Sally\",\n                \"lastname\": \"Brown\",\n                \"totalprice\": 111,\n                \"depositpaid\": True,\n                \"bookingdates\": {\n                    \"checkin\": \"2013-02-23\",\n                    \"checkout\": \"2014-10-23\"\n                },\n                \"additionalneeds\": \"Breakfast\"\n            }\n        )\n        self.assertEqual(result, \"raw_bookings_entity_id\")\n\nif __name__ == \"__main__\":\n    # Uncomment below line to run tests when script is executed directly\n    # unittest.main()\n    booking_id = 1  # Example booking ID\n    token = \"your_auth_token\"  # Replace with actual token\n    ingest_data(booking_id, token)  # Example call to ingest_data\n# ```\n# \n# ### Explanation:\n# - **`ingest_data` Function**: This function takes a booking ID and a token as parameters, fetches the booking data from the Restful Booker API, maps the data to the `raw_bookings_entity` structure, and saves it using `entity_service.add_item()`.\n# - **Logging**: The function logs significant actions and errors for better traceability.\n# - **Error Handling**: The function captures exceptions and logs any errors encountered during the API call or entity storage.\n# - **Unit Tests**: The tests use `unittest` and mocks to simulate API responses and the behavior of the `entity_service`. This allows for isolated testing of the `ingest_data` function without making actual HTTP requests.\n# \n# You can run the tests by uncommenting the `unittest.main()` line in the main script block or run the code directly to call the `ingest_data` function with a specified booking ID and token.
