{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Cyoda design",
    "type": "object",
    "entities": [
        {
            "entity_name": "data_analysis_job",
            "entity_type": "JOB",
            "entity_source": "SCHEDULED",
            "depends_on_entity": "None",
            "entity_workflow": {
                "name": "data_analysis_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": [
                    {
                        "name": "download_london_houses_data",
                        "description": "Download the London Houses data for analysis.",
                        "start_state": "None",
                        "start_state_description": "Initial state before data download.",
                        "end_state": "data_downloaded",
                        "end_state_description": "London Houses data has been successfully downloaded.",
                        "process": {
                            "name": "download_data_process",
                            "description": "Process to download the London Houses data.",
                            "adds_new_entites": "raw_london_houses_data_entity"
                        }
                    },
                    {
                        "name": "analyze_data",
                        "description": "Analyze the downloaded London Houses data using pandas.",
                        "start_state": "data_downloaded",
                        "start_state_description": "London Houses data has been downloaded and is ready for analysis.",
                        "end_state": "data_analyzed",
                        "end_state_description": "Data analysis has been completed.",
                        "process": {
                            "name": "analyze_data_process",
                            "description": "Process to analyze the London Houses data.",
                            "adds_new_entites": "analyzed_london_houses_data_entity"
                        }
                    },
                    {
                        "name": "save_report",
                        "description": "Save the analysis report of the London Houses data.",
                        "start_state": "data_analyzed",
                        "start_state_description": "Data analysis has been completed and is ready to save the report.",
                        "end_state": "report_saved",
                        "end_state_description": "Analysis report has been successfully saved.",
                        "process": {
                            "name": "save_report_process",
                            "description": "Process to save the analysis report.",
                            "adds_new_entites": "report_entity"
                        }
                    }
                ]
            }
        },
        {
            "entity_name": "raw_london_houses_data_entity",
            "entity_type": "EXTERNAL_SOURCES_PULL_BASED_RAW_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_analysis_job",
            "entity_workflow": {
                "name": "raw_data_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "analyzed_london_houses_data_entity",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_analysis_job",
            "entity_workflow": {
                "name": "analyzed_data_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "report_entity",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_analysis_job",
            "entity_workflow": {
                "name": "report_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        }
    ]
}