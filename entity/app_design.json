{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Cyoda design",
    "type": "object",
    "entities": [
        {
            "entity_name": "data_ingestion_job",
            "entity_type": "JOB",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "None",
            "entity_workflow": {
                "name": "data_ingestion_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": [
                    {
                        "name": "scheduled_ingestion",
                        "description": "Triggered by a scheduled job to ingest data.",
                        "start_state": "None",
                        "start_state_description": "Initial state before data ingestion.",
                        "end_state": "data_ingested",
                        "end_state_description": "Data has been successfully ingested.",
                        "process": {
                            "name": "ingest_raw_data",
                            "description": "Process to ingest raw data from the specified API.",
                            "adds_new_entites": "raw_data_entity"
                        }
                    },
                    {
                        "name": "save_raw_data",
                        "description": "Save the ingested raw data into the raw data entity.",
                        "start_state": "data_ingested",
                        "start_state_description": "Data has been ingested and is ready to be saved.",
                        "end_state": "raw_data_saved",
                        "end_state_description": "Raw data has been saved successfully.",
                        "process": {
                            "name": "save_raw_data",
                            "description": "Process to save raw data into the entity.",
                            "adds_new_entites": "None"
                        }
                    }
                ]
            }
        },
        {
            "entity_name": "raw_data_entity",
            "entity_type": "EXTERNAL_SOURCES_PULL_BASED_RAW_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_ingestion_job",
            "entity_workflow": {
                "name": "raw_data_entity_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "analyzed_data_entity",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "raw_data_entity",
            "entity_workflow": {
                "name": "analyzed_data_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": [
                    {
                        "name": "analyze_raw_data",
                        "description": "Analyze the raw data using pandas.",
                        "start_state": "raw_data_saved",
                        "start_state_description": "Raw data has been saved and is ready for analysis.",
                        "end_state": "data_analyzed",
                        "end_state_description": "Data has been successfully analyzed.",
                        "process": {
                            "name": "analyze_raw_data",
                            "description": "Process to analyze the raw data using pandas.",
                            "adds_new_entites": "None"
                        }
                    }
                ]
            }
        },
        {
            "entity_name": "report_entity",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "analyzed_data_entity",
            "entity_workflow": {
                "name": "report_generation_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": [
                    {
                        "name": "generate_report",
                        "description": "Generate a report based on the analyzed data.",
                        "start_state": "data_analyzed",
                        "start_state_description": "Data has been analyzed and is ready for report generation.",
                        "end_state": "report_generated",
                        "end_state_description": "Report has been successfully generated.",
                        "process": {
                            "name": "generate_report",
                            "description": "Process to create and store the report.",
                            "adds_new_entites": "None"
                        }
                    }
                ]
            }
        }
    ]
}