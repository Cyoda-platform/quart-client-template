{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Cyoda design",
    "type": "object",
    "entities": [
        {
            "entity_name": "pet_data_ingestion_job",
            "entity_type": "JOB",
            "entity_source": "SCHEDULED",
            "depends_on_entity": "None",
            "entity_workflow": {
                "name": "pet_data_ingestion_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": [
                    {
                        "name": "start_data_ingestion",
                        "description": "Ingest pet data based on specified parameters.",
                        "start_state": "None",
                        "start_state_description": "Initial state before pet data ingestion.",
                        "end_state": "data_ingested",
                        "end_state_description": "Pet data has been successfully ingested.",
                        "process": {
                            "name": "ingest_pet_data",
                            "description": "Process to ingest pet data from the API based on user parameters.",
                            "adds_new_entites": "raw_pet_data_entity"
                        }
                    }
                ]
            }
        },
        {
            "entity_name": "raw_pet_data_entity",
            "entity_type": "EXTERNAL_SOURCES_PULL_BASED_RAW_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "pet_data_ingestion_job",
            "entity_workflow": {
                "name": "raw_pet_data_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "transformed_pet_data_entity",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "pet_data_ingestion_job",
            "entity_workflow": {
                "name": "transformed_pet_data_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": [
                    {
                        "name": "transform_pet_data",
                        "description": "Transform the raw pet data into a user-friendly format.",
                        "start_state": "raw_data_received",
                        "start_state_description": "Raw pet data has been received and is ready for transformation.",
                        "end_state": "data_transformed",
                        "end_state_description": "Pet data has been successfully transformed.",
                        "process": {
                            "name": "transform_pet_data_process",
                            "description": "Process to rename fields and incorporate additional attributes.",
                            "adds_new_entites": "final_pet_data_entity"
                        }
                    }
                ]
            }
        },
        {
            "entity_name": "final_pet_data_entity",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "transformed_pet_data_entity",
            "entity_workflow": {
                "name": "final_pet_data_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        }
    ]
}