{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Cyoda design",
    "type": "object",
    "entities": [
        {
            "entity_name": "data_ingestion_job",
            "entity_type": "JOB",
            "entity_source": "API_REQUEST",
            "depends_on_entity": "None",
            "entity_workflow": {
                "name": "data_ingestion_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": [
                    {
                        "name": "start_data_ingestion",
                        "description": "Start the data ingestion process from the API.",
                        "start_state": "None",
                        "start_state_description": "Initial state before data ingestion.",
                        "end_state": "data_retrieved",
                        "end_state_description": "Data has been successfully retrieved.",
                        "process": {
                            "name": "ingest_raw_data",
                            "description": "Process to ingest raw data from the specified API.",
                            "adds_new_entites": "raw_data_entity"
                        }
                    },
                    {
                        "name": "process_data",
                        "description": "Process the retrieved data.",
                        "start_state": "data_retrieved",
                        "start_state_description": "Data has been retrieved and is ready for processing.",
                        "end_state": "data_processed",
                        "end_state_description": "Data has been successfully processed.",
                        "process": {
                            "name": "process_inventory_data",
                            "description": "Process the raw inventory data.",
                            "adds_new_entites": "secondary_data_entity"
                        }
                    }
                ]
            }
        },
        {
            "entity_name": "raw_data_entity",
            "entity_type": "EXTERNAL_SOURCES_PULL_BASED_RAW_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_ingestion_job",
            "entity_workflow": {
                "name": "raw_data_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "secondary_data_entity",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_ingestion_job",
            "entity_workflow": {
                "name": "secondary_data_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": [
                    {
                        "name": "process_secondary_data",
                        "description": "Transform raw data into secondary data.",
                        "start_state": "data_processed",
                        "start_state_description": "Data has been processed and is ready for transformation.",
                        "end_state": "secondary_data_processed",
                        "end_state_description": "Secondary data has been successfully generated.",
                        "process": {
                            "name": "transform_data",
                            "description": "Transform the data into a secondary format for reporting.",
                            "adds_new_entites": "report_entity"
                        }
                    }
                ]
            }
        },
        {
            "entity_name": "report_entity",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "API_REQUEST",
            "depends_on_entity": "secondary_data_entity",
            "entity_workflow": {
                "name": "report_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": [
                    {
                        "name": "create_report",
                        "description": "Generate a report from the secondary data.",
                        "start_state": "secondary_data_processed",
                        "start_state_description": "Secondary data is ready for report generation.",
                        "end_state": "report_generated",
                        "end_state_description": "The report has been successfully generated.",
                        "process": {
                            "name": "generate_report",
                            "description": "Process to create a report based on secondary data.",
                            "adds_new_entites": ""
                        }
                    }
                ]
            }
        }
    ]
}