{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Cyoda design",
    "type": "object",
    "entities": [
        {
            "entity_name": "data_ingestion_job",
            "entity_type": "JOB",
            "entity_source": "SCHEDULED",
            "depends_on_entity": "None",
            "entity_workflow": {
                "name": "data_ingestion_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": [
                    {
                        "name": "start_data_ingestion",
                        "description": "Start the data ingestion process from the API.",
                        "start_state": "None",
                        "start_state_description": "Initial state before data ingestion.",
                        "end_state": "data_ingested",
                        "end_state_description": "Data has been successfully ingested.",
                        "process": {
                            "name": "ingest_raw_data",
                            "description": "Process to ingest raw data from the specified API.",
                            "adds_new_entites": "raw_data_entity"
                        }
                    },
                    {
                        "name": "transform_data",
                        "description": "Transform retrieved raw data into secondary data by applying user-defined transformations.",
                        "start_state": "data_ingested",
                        "start_state_description": "Data has been ingested and is ready for transformation.",
                        "end_state": "data_transformed",
                        "end_state_description": "Data has been successfully transformed.",
                        "process": {
                            "name": "transform_data_process",
                            "description": "Process to transform raw data into secondary data.",
                            "adds_new_entites": "transformed_data_entity"
                        }
                    },
                    {
                        "name": "enrich_data",
                        "description": "Enrich the transformed data with additional information.",
                        "start_state": "data_transformed",
                        "start_state_description": "Data has been transformed and is ready for enrichment.",
                        "end_state": "data_enriched",
                        "end_state_description": "Data has been successfully enriched.",
                        "process": {
                            "name": "enrich_data_process",
                            "description": "Process to enrich transformed data.",
                            "adds_new_entites": "enriched_data_entity"
                        }
                    },
                    {
                        "name": "aggregate_data",
                        "description": "Aggregate the enriched data for final reporting.",
                        "start_state": "data_enriched",
                        "start_state_description": "Data has been enriched and is ready for aggregation.",
                        "end_state": "data_aggregated",
                        "end_state_description": "Data has been successfully aggregated.",
                        "process": {
                            "name": "aggregate_data_process",
                            "description": "Process to aggregate enriched data.",
                            "adds_new_entites": "aggregated_data_entity"
                        }
                    },
                    {
                        "name": "add_report",
                        "description": "Generate and store a report from the aggregated data.",
                        "start_state": "data_aggregated",
                        "start_state_description": "Data has been aggregated and is ready for reporting.",
                        "end_state": "report_generated",
                        "end_state_description": "Report has been successfully generated and stored.",
                        "process": {
                            "name": "generate_report_process",
                            "description": "Process to generate a report from aggregated data.",
                            "adds_new_entites": "report_entity"
                        }
                    }
                ]
            }
        },
        {
            "entity_name": "raw_data_entity",
            "entity_type": "EXTERNAL_SOURCES_PULL_BASED_RAW_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_ingestion_job",
            "entity_workflow": {
                "name": "raw_data_entity_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "transformed_data_entity",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_ingestion_job",
            "entity_workflow": {
                "name": "transformed_data_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "enriched_data_entity",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_ingestion_job",
            "entity_workflow": {
                "name": "enriched_data_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "aggregated_data_entity",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_ingestion_job",
            "entity_workflow": {
                "name": "aggregated_data_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "report_entity",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_ingestion_job",
            "entity_workflow": {
                "name": "report_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        }
    ]
}