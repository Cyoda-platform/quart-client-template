                "name": "library_management_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": [
                    {
                        "name": "manage_books",
                        "description": "Manage books by adding, updating, or deleting.",
                        "start_state": "None",
                        "start_state_description": "Initial state for managing books.",
                        "end_state": "books_managed",
                        "end_state_description": "Books have been successfully managed.",
                        "process": {
                            "name": "process_books",
                            "description": "Process for managing books through API.",
                            "adds_new_entites": "book_entity"
                        }
                    },
                    {
                        "name": "manage_authors",
                        "description": "Manage authors by adding, updating, or deleting.",
                        "start_state": "books_managed",
                        "start_state_description": "Books have been managed and ready for author management.",
                        "end_state": "authors_managed",
                        "end_state_description": "Authors have been successfully managed.",
                        "process": {
                            "name": "process_authors",
                            "description": "Process for managing authors through API.",
                            "adds_new_entites": "author_entity"
                        }
                    },
                    {
                        "name": "manage_users",
                        "description": "Manage users by adding, updating, or deleting.",
                        "start_state": "authors_managed",
                        "start_state_description": "Authors have been managed and ready for user management.",
                        "end_state": "users_managed",
                        "end_state_description": "Users have been successfully managed.",
                        "process": {
                            "name": "process_users",
                            "description": "Process for managing users through API.",
                            "adds_new_entites": "user_entity"
                        }
                    },
                    {
                        "name": "manage_tasks",
                        "description": "Manage tasks associated with users.",
                        "start_state": "users_managed",
                        "start_state_description": "Users have been managed and ready for task management.",
                        "end_state": "tasks_managed",
                        "end_state_description": "Tasks have been successfully managed.",
                        "process": {
                            "name": "process_tasks",
                            "description": "Process for managing tasks through API.",
                            "adds_new_entites": "task_entity"
                        }
                    }
                ]
            }
        },
        {
            "entity_name": "book_entity",
            "entity_type": "EXTERNAL_SOURCES_PULL_BASED_RAW_DATA",
