{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Cyoda design",
    "type": "object",
    "entities": [
        {
            "entity_name": "data_ingestion_job",
            "entity_type": "JOB",
            "entity_source": "API_REQUEST",
            "depends_on_entity": "None",
            "entity_workflow": {
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "name": "data_ingestion_workflow",
                "transitions": [
                    {
                        "name": "download_data",
                        "description": "Download London Houses Data from the external source.",
                        "start_state": "None",
                        "start_state_description": "Initial state before data download.",
                        "end_state": "data_downloaded",
                        "end_state_description": "Data has been successfully downloaded.",
                        "process": {
                            "name": "download_data_processor",
                            "description": "Processor to handle data download.",
                            "adds_new_entites": "london_houses_data_entity"
                        }
                    },
                    {
                        "name": "analyze_data",
                        "description": "Analyze the downloaded data using pandas.",
                        "start_state": "data_downloaded",
                        "start_state_description": "Data has been downloaded and is ready for analysis.",
                        "end_state": "data_analyzed",
                        "end_state_description": "Data analysis has been successfully completed.",
                        "process": {
                            "name": "analyze_data_processor",
                            "description": "Processor to analyze data using pandas.",
                            "adds_new_entites": "analyzed_data_entity"
                        }
                    },
                    {
                        "name": "generate_report",
                        "description": "Generate a report based on the analyzed data.",
                        "start_state": "data_analyzed",
                        "start_state_description": "Data analysis is complete and ready for report generation.",
                        "end_state": "report_generated",
                        "end_state_description": "Report has been successfully generated.",
                        "process": {
                            "name": "generate_report_processor",
                            "description": "Processor to generate report from analyzed data.",
                            "adds_new_entites": "report_entity"
                        }
                    }
                ]
            }
        },
        {
            "entity_name": "london_houses_data_entity",
            "entity_type": "EXTERNAL_SOURCES_PULL_BASED_RAW_DATA",
            "entity_source": "API_REQUEST",
            "depends_on_entity": "data_ingestion_job",
            "entity_workflow": {
                "name": "london_houses_data_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "analyzed_data_entity",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_ingestion_job",
            "entity_workflow": {
                "name": "analyzed_data_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "report_entity",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_ingestion_job",
            "entity_workflow": {
                "name": "report_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        }
    ]
}