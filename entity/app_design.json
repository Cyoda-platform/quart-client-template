{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Improved Cyoda design",
    "can_proceed": true,
    "entities": [
        {
            "entity_name": "user_feedback_processing_job",
            "entity_type": "JOB",
            "entity_source": "SCHEDULED",
            "depends_on_entity": "None",
            "entity_workflow": {
                "name": "user_feedback_processing_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": [
                    {
                        "name": "scheduled_feedback_fetch_and_analysis",
                        "description": "Fetch user feedback and analyze sentiment in one job.",
                        "start_state": "None",
                        "start_state_description": "Initial state before processing user feedback.",
                        "end_state": "report_generated",
                        "end_state_description": "Sentiment analysis completed and report generated.",
                        "process": {
                            "name": "fetch_and_analyze_feedback_process",
                            "description": "Process to fetch user feedback and analyze sentiment, generating a report.",
                            "adds_new_entites": "report_entity"
                        }
                    }
                ]
            }
        },
        {
            "entity_name": "report_entity",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "user_feedback_processing_job",
            "entity_workflow": {
                "name": "report_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        }
    ]
}