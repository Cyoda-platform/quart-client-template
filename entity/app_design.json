{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Cyoda design",
    "type": "object",
    "entities": [
        {
            "entity_name": "data_ingestion_job",
            "entity_type": "JOB",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "None",
            "entity_workflow": {
                "name": "data_ingestion_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": [
                    {
                        "name": "start_data_ingestion",
                        "description": "Triggered on schedule to ingest data from the API.",
                        "start_state": "None",
                        "start_state_description": "Initial state before data ingestion.",
                        "end_state": "data_ingested",
                        "end_state_description": "Data has been successfully ingested.",
                        "process": {
                            "name": "ingest_raw_data",
                            "description": "Process to ingest raw data from the specified API.",
                            "adds_new_entites": "raw_data_entity"
                        }
                    },
                    {
                        "name": "process_raw_data",
                        "description": "Process the ingested raw data.",
                        "start_state": "data_ingested",
                        "start_state_description": "Raw data has been ingested and is ready for processing.",
                        "end_state": "raw_data_created",
                        "end_state_description": "Raw data has been successfully created.",
                        "process": {
                            "name": "process_raw_data",
                            "description": "Processing raw data to prepare for aggregation.",
                            "adds_new_entites": "aggregated_data_entity"
                        }
                    }
                ]
            }
        },
        {
            "entity_name": "raw_data_entity",
            "entity_type": "EXTERNAL_SOURCES_PULL_BASED_RAW_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_ingestion_job",
            "entity_workflow": {
                "name": "raw_data_entity_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "aggregated_data_entity",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "raw_data_entity",
            "entity_workflow": {
                "name": "aggregated_data_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": [
                    {
                        "name": "aggregate_data",
                        "description": "Aggregate the processed raw data.",
                        "start_state": "raw_data_created",
                        "start_state_description": "Raw data has been processed and is ready for aggregation.",
                        "end_state": "data_aggregated",
                        "end_state_description": "Data has been successfully aggregated.",
                        "process": {
                            "name": "aggregate_raw_data",
                            "description": "Aggregating processed raw data for reporting.",
                            "adds_new_entites": "report_entity"
                        }
                    }
                ]
            }
        },
        {
            "entity_name": "report_entity",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "aggregated_data_entity",
            "entity_workflow": {
                "name": "report_generation_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": [
                    {
                        "name": "generate_report",
                        "description": "Generate a report from the aggregated data.",
                        "start_state": "data_aggregated",
                        "start_state_description": "Aggregated data is available and ready for reporting.",
                        "end_state": "report_generated",
                        "end_state_description": "Report has been successfully generated.",
                        "process": {
                            "name": "create_report",
                            "description": "Creating report based on aggregated data.",
                            "adds_new_entites": "None"
                        }
                    }
                ]
            }
        }
    ]
}