{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Cyoda design",
    "type": "object",
    "entities": [
        {
            "entity_name": "data_ingestion_job",
            "entity_type": "JOB",
            "entity_source": "API_REQUEST",
            "depends_on_entity": "None",
            "entity_workflow": {
                "name": "data_ingestion_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": [
                    {
                        "name": "ingest_data",
                        "description": "Trigger the data ingestion process from the Automation Exercise API.",
                        "start_state": "None",
                        "start_state_description": "Initial state before data ingestion.",
                        "end_state": "data_ingested",
                        "end_state_description": "Data has been successfully ingested.",
                        "process": {
                            "name": "ingest_raw_data",
                            "description": "Process to retrieve raw data from the API.",
                            "adds_new_entites": "raw_data_entity"
                        }
                    },
                    {
                        "name": "transform_data",
                        "description": "Transform the raw data into a cleaned format.",
                        "start_state": "data_ingested",
                        "start_state_description": "Data has been ingested and is ready for transformation.",
                        "end_state": "data_transformed",
                        "end_state_description": "Data has been successfully transformed.",
                        "process": {
                            "name": "transform_data_process",
                            "description": "Process to clean and format the raw data.",
                            "adds_new_entites": "transformed_data_entity"
                        }
                    },
                    {
                        "name": "aggregate_data",
                        "description": "Aggregate the transformed data based on specified criteria.",
                        "start_state": "data_transformed",
                        "start_state_description": "Data has been transformed and is ready for aggregation.",
                        "end_state": "data_aggregated",
                        "end_state_description": "Data has been successfully aggregated.",
                        "process": {
                            "name": "aggregate_data_process",
                            "description": "Process to summarize the transformed data.",
                            "adds_new_entites": "aggregated_data_entity"
                        }
                    },
                    {
                        "name": "generate_report",
                        "description": "Create a report summarizing the aggregated data.",
                        "start_state": "data_aggregated",
                        "start_state_description": "Data has been aggregated and is ready for reporting.",
                        "end_state": "report_generated",
                        "end_state_description": "Report has been successfully generated.",
                        "process": {
                            "name": "generate_report_process",
                            "description": "Process to generate the report from aggregated data.",
                            "adds_new_entites": "report_entity"
                        }
                    },
                    {
                        "name": "send_report",
                        "description": "Send the generated report to the admin's email.",
                        "start_state": "report_generated",
                        "start_state_description": "Report has been generated and is ready to be sent.",
                        "end_state": "report_sent",
                        "end_state_description": "Report has been successfully sent to the admin.",
                        "process": {
                            "name": "email_report_process",
                            "description": "Process to send the report via email.",
                            "adds_new_entites": ""
                        }
                    }
                ]
            }
        },
        {
            "entity_name": "raw_data_entity",
            "entity_type": "EXTERNAL_SOURCES_PULL_BASED_RAW_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_ingestion_job",
            "entity_workflow": {
                "name": "raw_data_entity_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "transformed_data_entity",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_ingestion_job",
            "entity_workflow": {
                "name": "transformed_data_entity_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "aggregated_data_entity",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_ingestion_job",
            "entity_workflow": {
                "name": "aggregated_data_entity_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "report_entity",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_ingestion_job",
            "entity_workflow": {
                "name": "report_entity_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        }
    ]
}