{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Cyoda design",
    "type": "object",
    "entities": [
        {
            "entity_name": "library_management_job",
            "entity_type": "JOB",
            "entity_source": "SCHEDULED",
            "depends_on_entity": "None",
            "entity_workflow": {
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "name": "library_management_workflow",
                "transitions": [
                    {
                        "name": "fetch_books",
                        "description": "Fetch all books from the API.",
                        "start_state": "None",
                        "start_state_description": "Initial state before fetching books.",
                        "end_state": "books_fetched",
                        "end_state_description": "All books have been successfully fetched.",
                        "process": {
                            "name": "fetch_books_process",
                            "description": "Process to call the /Books API to retrieve book list.",
                            "adds_new_entites": "book_entity"
                        }
                    },
                    {
                        "name": "fetch_authors",
                        "description": "Fetch all authors from the API.",
                        "start_state": "books_fetched",
                        "start_state_description": "Books have been fetched and authors are being retrieved.",
                        "end_state": "authors_fetched",
                        "end_state_description": "All authors have been successfully fetched.",
                        "process": {
                            "name": "fetch_authors_process",
                            "description": "Process to call the /Authors API to retrieve author list.",
                            "adds_new_entites": "author_entity"
                        }
                    },
                    {
                        "name": "fetch_users",
                        "description": "Fetch all users from the API.",
                        "start_state": "authors_fetched",
                        "start_state_description": "Authors have been fetched and users are being retrieved.",
                        "end_state": "users_fetched",
                        "end_state_description": "All users have been successfully fetched.",
                        "process": {
                            "name": "fetch_users_process",
                            "description": "Process to call the /Users API to retrieve user list.",
                            "adds_new_entites": "user_entity"
                        }
                    },
                    {
                        "name": "fetch_tasks",
                        "description": "Fetch all tasks from the API.",
                        "start_state": "users_fetched",
                        "start_state_description": "Users have been fetched and tasks are being retrieved.",
                        "end_state": "tasks_fetched",
                        "end_state_description": "All tasks have been successfully fetched.",
                        "process": {
                            "name": "fetch_tasks_process",
                            "description": "Process to call the /Tasks API to retrieve task list.",
                            "adds_new_entites": "task_entity"
                        }
                    },
                    {
                        "name": "fetch_user_activities",
                        "description": "Fetch user activities from the API.",
                        "start_state": "tasks_fetched",
                        "start_state_description": "Tasks have been fetched and user activities are being retrieved.",
                        "end_state": "user_activities_fetched",
                        "end_state_description": "User activities have been successfully fetched.",
                        "process": {
                            "name": "fetch_user_activities_process",
                            "description": "Process to call the /Activities API to retrieve user activity history.",
                            "adds_new_entites": "user_activity_entity"
                        }
                    }
                ]
            }
        },
        {
            "entity_name": "book_entity",
            "entity_type": "EXTERNAL_SOURCES_PULL_BASED_RAW_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "library_management_job",
            "entity_workflow": {
                "name": "book_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "author_entity",
            "entity_type": "EXTERNAL_SOURCES_PULL_BASED_RAW_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "library_management_job",
            "entity_workflow": {
                "name": "author_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "user_entity",
            "entity_type": "EXTERNAL_SOURCES_PULL_BASED_RAW_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "library_management_job",
            "entity_workflow": {
                "name": "user_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "task_entity",
            "entity_type": "EXTERNAL_SOURCES_PULL_BASED_RAW_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "library_management_job",
            "entity_workflow": {
                "name": "task_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "user_activity_entity",
            "entity_type": "EXTERNAL_SOURCES_PULL_BASED_RAW_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "library_management_job",
            "entity_workflow": {
                "name": "user_activity_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        }
    ]
}