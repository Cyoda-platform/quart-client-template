{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Cyoda design",
    "type": "object",
    "entities": [
        {
            "entity_name": "trip_management_job",
            "entity_type": "JOB",
            "entity_source": "SCHEDULED",
            "depends_on_entity": "None",
            "entity_workflow": {
                "name": "trip_management_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": [
                    {
                        "name": "manage_trip",
                        "description": "Manage trip scheduling and user assignments.",
                        "start_state": "None",
                        "start_state_description": "Initial state before managing trips.",
                        "end_state": "trip_managed",
                        "end_state_description": "Trip has been successfully managed.",
                        "process": {
                            "name": "manage_trip_process",
                            "description": "Process to manage trips, add/remove users, and handle events.",
                            "adds_new_entites": "trip_entity"
                        }
                    },
                    {
                        "name": "create_event",
                        "description": "Create an event within a trip.",
                        "start_state": "trip_managed",
                        "start_state_description": "Trip management is complete; ready to add events.",
                        "end_state": "event_created",
                        "end_state_description": "Event has been successfully created.",
                        "process": {
                            "name": "create_event_process",
                            "description": "Process to create new events associated with trips.",
                            "adds_new_entites": "event_entity"
                        }
                    }
                ]
            }
        },
        {
            "entity_name": "trip_entity",
            "entity_type": "BUSINESS_ENTITY",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "trip_management_job",
            "entity_workflow": {
                "name": "trip_entity_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "event_entity",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "trip_management_job",
            "entity_workflow": {
                "name": "event_entity_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "user_entity",
            "entity_type": "BUSINESS_ENTITY",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "trip_management_job",
            "entity_workflow": {
                "name": "user_entity_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        }
    ]
}