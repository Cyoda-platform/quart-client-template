{
    "description": "Finite state machine to handle weather fetch job processing",
    "name": "weather_fetch_job_workflow",
    "transitions": [
        {
            "automated": true,
            "description": "Validate job input and set processing status",
            "end_state": "job_validated",
            "end_state_description": "Job input validated and processing started",
            "name": "validate_job",
            "processes": {
                "externalized_processors": [
                    {
                        "description": "",
                        "name": "process_validate_job"
                    }
                ],
                "schedule_transition_processors": []
            },
            "start_state": "None",
            "start_state_description": "Initial state"
        },
        {
            "automated": true,
            "description": "Process locations to update cache entries",
            "end_state": "locations_processed",
            "end_state_description": "Locations processed and cached",
            "name": "process_locations",
            "processes": {
                "externalized_processors": [
                    {
                        "description": "",
                        "name": "process_process_locations"
                    }
                ],
                "schedule_transition_processors": []
            },
            "start_state": "job_validated",
            "start_state_description": "Job input validated and processing started"
        },
        {
            "automated": true,
            "description": "Finalize the job and mark as done",
            "end_state": "job_finished",
            "end_state_description": "Job processing completed",
            "name": "finalize_job",
            "processes": {
                "externalized_processors": [
                    {
                        "description": "",
                        "name": "process_finalize_job"
                    }
                ],
                "schedule_transition_processors": []
            },
            "start_state": "locations_processed",
            "start_state_description": "Locations processed and cached"
        }
    ]
}